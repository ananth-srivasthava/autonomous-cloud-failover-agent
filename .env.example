# ─────────────────────────────────────────────
#  IBM Watsonx.ai Credentials
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# IBM Cloud API Key — generate at https://cloud.ibm.com/iam/apikeys
IBM_API_KEY=your_ibm_cloud_api_key_here

# Watsonx.ai Project ID — found in your Watsonx project settings
WATSONX_PROJECT_ID=your_watsonx_project_id_here

# Watsonx.ai Service URL — match your region:
#   Dallas (default): https://us-south.ml.cloud.ibm.com
#   Tokyo:            https://jp-tok.ml.cloud.ibm.com
#   London:           https://eu-gb.ml.cloud.ibm.com
#   Frankfurt:        https://eu-de.ml.cloud.ibm.com
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# Flask secret key (change to a random string in production)
FLASK_SECRET_KEY=change-me-to-a-random-secret

# Flask environment
FLASK_ENV=development
FLASK_DEBUG=true
